# ============================================================
# PCMS 환경변수 설정 예시
# 이 파일을 복사하여 .env.development 등으로 만들어 사용하세요.
# 실제 값이 담긴 .env.* 파일은 절대 git에 커밋하지 마세요.
# ============================================================

# 실행 모드 (application-<PCMS_MODE>.properties 를 로드)
PCMS_MODE=development

# ── Database ──────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/kdy987_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────
# 256비트 이상의 랜덤 문자열 권장
# 생성 예시: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# ── 공공데이터
PUBLIC_DATA_API_KEY=e5e22c284503db8332064a44cffb10183a349dc92339f026f6ed7d9e0639f84a
