{
  "compilerOptions": {
    /* OS 간 대소문자 일관성 보장 - 필수 설정 */
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    
    /* shadcn/ui 초기화 에러 해결을 위한 별칭 선언 */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}